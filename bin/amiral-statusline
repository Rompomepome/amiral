#!/usr/bin/env bash
# amiral butin — statusline renderer (v0.13), installed to
# ~/.claude/butin/amiral-statusline.sh. Wired via settings.json:
#   {"statusLine": {"type": "command", "command": "bash <path>", "padding": 0}}
# (code.claude.com/docs/en/statusline.md, verified 2026-07-15).
#
# HONESTY INVARIANT (DESIGN-NOTES.md §1.2): this script NEVER computes a
# savings figure and NEVER reads butin.jsonl's content (mtime stat only).
# Every number printed here was already computed by core.awk and written to
# the cache by lib/butin/cache.sh — no second accounting implementation.
#
# Deliberately NO `set -e` (and no `set -u`): a statusline script must NEVER
# let an error become visible — Claude Code renders a blank line on non-zero
# exit / empty stdout, and a script that dies mid-render would flicker the
# UI every turn. Every code path below falls through to `exit 0`.
export LC_ALL=C

AMIRAL_HOME="${AMIRAL_HOME:-$HOME/.amiral}"
CACHE="$AMIRAL_HOME/butin-cache.tsv"

# The chained command lives in ~/.amiral (OUTSIDE Claude Code's workspace-trust
# boundary) yet we execute it on every render. Run it ONLY if it still matches
# the hash captured at install time (tamper-evident, like amiral-trust pins
# verify.sh) and is not group/world-writable. A silently-changed or loosened
# file is skipped, never executed. Not tamper-proof against an attacker who
# rewrites both the file and its .sha — but that closes the accidental, the
# shared-home, and the single-file-drop cases and never fails toward exec.
_prevcmd_trusted() {
  _f="$1"
  _perm="$(stat -c '%A' "$_f" 2>/dev/null || stat -f '%Sp' "$_f" 2>/dev/null || echo '')"
  case "$_perm" in ?????w*|????????w*) return 1 ;; esac   # group- or other-writable
  _h="$(shasum "$_f" 2>/dev/null | awk '{print $1}')"
  _p="$(cat "$_f.sha" 2>/dev/null)"
  [ -n "$_h" ] && [ -n "$_p" ] && [ "$_h" = "$_p" ]
}

# Run a shell command with a hard 2s cap WITHOUT relying on coreutils
# `timeout` (absent on stock macOS): background the command + a watchdog,
# wait on the command, then kill the watchdog. The watchdog's stdout is sent
# to /dev/null so it never pins this command-substitution's pipe open.
_run_capped() {
  if command -v timeout >/dev/null 2>&1; then
    timeout 2 sh -c "$1" 2>/dev/null; return
  fi
  # A backgrounded job's stdin is redirected to /dev/null in a non-interactive
  # shell, so the chained command would see empty input — capture our stdin to
  # a temp file and redirect it in explicitly. No mktemp -> run uncapped
  # rather than lose the chained line.
  _tf="$(mktemp 2>/dev/null)" || { sh -c "$1" 2>/dev/null; return; }
  cat > "$_tf" 2>/dev/null
  sh -c "$1" < "$_tf" 2>/dev/null &
  _cmdpid=$!
  ( sleep 2; kill "$_cmdpid" 2>/dev/null ) >/dev/null 2>&1 &
  _wpid=$!
  wait "$_cmdpid" 2>/dev/null
  kill "$_wpid" 2>/dev/null; wait "$_wpid" 2>/dev/null
  rm -f "$_tf" 2>/dev/null
}

# 1. Always consume stdin, even if we end up not using it ourselves — the
# previous (chained) command needs the full, unconsumed JSON (§1.6).
IN="$(cat 2>/dev/null)"

# 2. Chaining: a pre-existing statusline saved (and integrity-pinned) by
# `amiral statusline install`.
PREV=""
PREVCMD_FILE="$AMIRAL_HOME/statusline-prev-cmd"
if [ -s "$PREVCMD_FILE" ] && _prevcmd_trusted "$PREVCMD_FILE"; then
  PREVCMD="$(cat "$PREVCMD_FILE" 2>/dev/null)"
  if [ -n "$PREVCMD" ]; then
    PREV="$(printf '%s' "$IN" | _run_capped "$PREVCMD" | head -3)"
  fi
fi

# 3. Build OUR segment from the cache. One pass, matched BY KEY, no eval
# (file content is data, never code). Deliberately not a joined-fields read:
# tab is IFS *whitespace* in bash, so consecutive tabs collapse and one
# empty/absent value would silently shift every later field — wrong numbers
# on screen. Key-matched parsing also honors the cache contract: unknown
# keys ignored, absent keys default, order irrelevant.

# AMIRAL_PROFILE: an untrusted env var reaching a terminal (this renderer
# subprocess inherits the launching shell's exported vars — verified live).
# Sanitize before it ever touches the UI: only ^[a-z][a-z-]{0,11}$ passes
# (a plain case/glob check, no regex tool needed); anything else is treated
# as unset — no marker, and the raw value is never printed. See
# shell/amiral-profiles.sh for why this dedicated, never-exported,
# per-command var is the only honest profile signal (AMIRAL_BRAIN/
# AMIRAL_HANDS leak from `export`ed prefs into every later bare `claude`
# launch in the same shell — a false "amiral on").
PROFILE=""
_p="${AMIRAL_PROFILE:-}"
case "$_p" in
  [!a-z]*|"") : ;;                # doesn't start a-z, or empty/unset -> reject
  *[!a-z-]*)  : ;;                # a char outside [a-z-] anywhere -> reject
  *) [ "${#_p}" -le 12 ] && PROFILE="$_p" ;;
esac

SEG=""
PLAIN=""
CV=""; GEN_EPOCH=""; MODE=""; NET_TOTAL=""; NET_TODAY=""
PREM_TOTAL=""; PREM_TODAY=""; MEASURED=""; UNMEASURED=""; PENDING=""; ESC_TODAY=""
if [ -f "$CACHE" ]; then
  while IFS=$'\t' read -r K V; do
    V="${V%$'\r'}"   # tolerate a CRLF-edited cache: a stray \r would fail every match below
    case "$K" in
      v)                  CV="$V" ;;
      generated_epoch)    GEN_EPOCH="$V" ;;
      mode)               MODE="$V" ;;
      net_total)          NET_TOTAL="$V" ;;
      net_today)          NET_TODAY="$V" ;;
      prem_avoided_total) PREM_TOTAL="$V" ;;
      prem_avoided_today) PREM_TODAY="$V" ;;
      measured)           MEASURED="$V" ;;
      unmeasured)         UNMEASURED="$V" ;;
      pending)            PENDING="$V" ;;
      esc_today)          ESC_TODAY="$V" ;;
    esac
  done < "$CACHE" 2>/dev/null

  CORRUPT=0
  [ "$CV" = "1" ] || CORRUPT=1
  case "${NET_TOTAL:-}" in (*[!0-9.eE+-]*|"") CORRUPT=1 ;; esac
  case "${NET_TODAY:-0}" in (*[!0-9.eE+-]*) CORRUPT=1 ;; esac
  # Count fields are non-negative integers by construction (core.awk %d /
  # cache.sh awk count). Anything else is a corrupt cache and the whole
  # segment goes silent (§1.8 treat-as-absent) — NOT rendered raw. Without
  # this, BWK awk's -v strnum rule turns covbar's `m>0` into a STRING
  # comparison for non-numeric m ("corrupt" > "0" is true), which would
  # paint a filled cell for zero real coverage — a fabricated measurement.
  # A negative count ("-5") is equally impossible and would cancel inside
  # the bar's denominator into a false-full bar; the digits-only gate
  # rejects both.
  case "${MEASURED:-0}"   in (*[!0-9]*) CORRUPT=1 ;; esac
  case "${UNMEASURED:-0}" in (*[!0-9]*) CORRUPT=1 ;; esac
  case "${PENDING:-0}"    in (*[!0-9]*) CORRUPT=1 ;; esac
  case "${ESC_TODAY:-0}"  in (*[!0-9]*) CORRUPT=1 ;; esac

  if [ "$CORRUPT" = "0" ]; then
    # MUTE: suppresses good news only. A net-negative day always shows —
    # honesty outranks mute (§1.5).
    MUTED=0
    if [ -f "$AMIRAL_HOME/statusline-mute" ] \
       && awk -v n="${NET_TODAY:-0}" 'BEGIN{exit !(n>=0)}' 2>/dev/null; then
      MUTED=1
    fi

    if [ "$MUTED" = "0" ]; then
      # colors (respect NO_COLOR): from TODAY's sign, both modes.
      if [ -n "${NO_COLOR:-}" ]; then
        GREEN=""; AMBER=""; DIMC=""; CYANB=""; RST=""
      else
        GREEN=$'\033[32m'; AMBER=$'\033[33m'; DIMC=$'\033[2m'
        # v0.13.2: the profile token's color — BOLD (not dim) + a hue
        # (cyan) that carries no good/bad meaning, so it never competes
        # with green/amber, which stay reserved for today's sign.
        CYANB=$'\033[1;36m'; RST=$'\033[0m'
      fi
      # Clamp sub-cent noise: a -$0.003 rounding residual must not render as
      # an amber "loss" for a magnitude the 2dp display shows as $0.00. A
      # material negative day (|net| >= 0.005) is untouched — still amber,
      # still shown, mute still can't hide it.
      NET_TODAY="$(awk -v n="${NET_TODAY:-0}" 'BEGIN{ if (n<0.005 && n>-0.005) n=0; printf "%.6f", n }')"
      NET_TOTAL="$(awk -v n="${NET_TOTAL:-0}" 'BEGIN{ if (n<0.005 && n>-0.005) n=0; printf "%.6f", n }')"
      COL="$DIMC"
      if awk -v n="${NET_TODAY:-0}" 'BEGIN{exit !(n>0)}' 2>/dev/null; then COL="$GREEN"
      elif awk -v n="${NET_TODAY:-0}" 'BEGIN{exit !(n<0)}' 2>/dev/null; then COL="$AMBER"
      fi

      # sign + "$" + abs value, 2dp — "+$0.43" / "-$0.12" (ASCII minus).
      signed_dollar() {
        # `if (v==0) v=0` drops IEEE negative zero: -0.00 compares >=0 (sign
        # "+") but %.2f would still print its sign bit -> "+$-0.00".
        awk -v n="$1" 'BEGIN{ s=(n<0)?"-":"+"; v=(n<0)?-n:n; if (v==0) v=0; printf "%s$%.2f", s, v }'
      }
      # humanize a token count: <1000 raw, <100k one decimal + k, else integer k.
      humanize() {
        awk -v n="$1" 'BEGIN{ n0=n+0
          if (n0<1000) printf "%d", n0
          else if (n0<100000) printf "%.1fk", n0/1000
          else printf "%dk", int(n0/1000) }'
      }

      # Coverage bar: a small 5-cell bar (echoes Claude Code's own context
      # meter — filled/empty cells) over the ONLY honest denominator this
      # cache has: measured+pending+unmeasured, every event is exactly one
      # of the three. HONESTY ROUNDING: 5/5 filled only at EXACTLY 100%
      # coverage; floor otherwise; never 0 filled when measured>0 (a sliver
      # of real coverage must never render as literally nothing). One awk
      # call, this file's idiom (see signed_dollar/humanize above).
      # No such bar for savings/prem-avoided totals anywhere in this file:
      # a dollar or token total has NO natural maximum, so any "scale" for
      # it would be a fabricated number — never draw one.
      covbar() {
        awk -v m="$1" -v p="$2" -v u="$3" 'BEGIN{
          # Force numeric context up front: -v strings compare as STRINGS in
          # relationals when they do not look numeric ("corrupt">0 is true in
          # BWK awk). The digits-only CORRUPT gate upstream already rejects
          # such caches; this keeps covbar honest even if called differently.
          m=m+0; p=p+0; u=u+0
          tot = m+p+u
          if (tot<=0) exit
          frac = m/tot
          filled = int(frac*5)
          if (frac>=1) filled=5
          if (filled==0 && m>0) filled=1
          if (filled>5) filled=5
          if (filled<0) filled=0
          bar=""
          for (i=0;i<filled;i++) bar = bar "▰"
          for (i=filled;i<5;i++) bar = bar "▱"
          printf "%s", bar
        }'
      }

      # SPINNER (v0.13.2): a live-work indicator, computed here so both
      # modes below can slot it in identically, always inside this
      # CORRUPT-gated block (T-S20 extends naturally: a corrupt cache
      # renders no glyph, spinner included). PENDING>0 draws one of 10
      # moving braille frames; PENDING==0 with data present draws the
      # static ⠿ (deliberately NOT a member of the frame set — an
      # unambiguous "settled, nothing in flight"); total==0 draws nothing
      # (a spinner over no data would be motion for nothing).
      # MOTION SEMANTIC: the frame index is generated_epoch % 10, and that
      # epoch only changes when cache.sh (the producer) writes a NEW
      # snapshot — so the glyph only advances when a fresh measurement/
      # receipt pass lands while work is still pending. This is not a
      # wall-clock animation: render the SAME cache twice, any time apart,
      # and the frame is byte-identical both times; only a new snapshot
      # moves it.
      spin_glyph() {
        # Route the arithmetic through awk, this file's idiom for
        # anything numeric (see covbar/humanize/signed_dollar above):
        # m/p/u are digits-only-or-absent by the CORRUPT gate upstream,
        # but a raw bash `$(( ))` on a leading-zero value ("008") would
        # still be parsed as octal and could error straight to stderr —
        # forbidden here. awk's string-to-number conversion has no such
        # octal ambiguity. Final glyph selection is still a plain `case`
        # table below (never `${FRAMES:i:1}`: under LC_ALL=C bash slices
        # BYTES and every braille glyph here is 3 UTF-8 bytes, so a
        # byte-slice would print a garbage third of a glyph).
        _sidx="$(awk -v m="$1" -v p="$2" -v u="$3" -v ge="$4" 'BEGIN{
          m=m+0; p=p+0; u=u+0
          if (m+p+u<=0) { print "none"; exit }
          if (p>0) {
            # length cap, not just digits: awk holds numbers as C doubles,
            # so an all-digit epoch past ~18 digits loses integer precision
            # and `%d` of the modulo can land OUTSIDE 0-9 (observed: -32 on
            # macOS onetrueawk) — the case table below would then silently
            # drop the glyph while pending>0. Real epochs are 10 digits
            # until 2286; anything longer is a corrupt value whose frame is
            # underivable -> frame 0, glyph still shown (its PRESENCE means
            # pending>0; only its MOTION needs a trustworthy epoch).
            # length() over a brace interval: BWK awk has no {n,m} support.
            if (ge !~ /^[0-9]+$/ || length(ge) > 10) ge=0
            printf "%d", (ge+0) % 10
          } else print "settled"
        }')"
        case "$_sidx" in
          ""|none) return ;;   # empty = awk itself failed: claim nothing
          settled) printf '⠿' ;;
          0) printf '⠋' ;;
          1) printf '⠙' ;;
          2) printf '⠹' ;;
          3) printf '⠸' ;;
          4) printf '⠼' ;;
          5) printf '⠴' ;;
          6) printf '⠦' ;;
          7) printf '⠧' ;;
          8) printf '⠇' ;;
          9) printf '⠏' ;;
          # Default: only reachable from the p>0 printf branch emitting an
          # out-of-range index (a numeric edge the length cap should already
          # prevent) — pending IS >0 there, so a frame-0 glyph is honest;
          # silent disappearance while work is in flight would not be.
          *) printf '⠋' ;;
        esac
      }
      SPIN="$(spin_glyph "${MEASURED:-0}" "${PENDING:-0}" "${UNMEASURED:-0}" "${GEN_EPOCH:-}")"

      # HEAD / ANCHOR SEMANTICS (v0.13.2): ⚓ now means, specifically, "an
      # amiral profile launched this session" — nothing more. It is a
      # TEXT-level signal (glyph presence/absence), not a color, because a
      # color-only distinction dies under NO_COLOR while text survives it.
      # That claim is exactly what the sanitized AMIRAL_PROFILE var above
      # proves — no more. butin still measures a bare `claude` session the
      # same way; its numbers just render unflagged, with no anchor and no
      # profile token. So the anchor leads the segment ONLY when PROFILE
      # is non-empty; otherwise HEAD is empty and the line opens directly
      # on the money/plan figures.
      if [ -n "$PROFILE" ]; then
        HEAD="⚓ ${PROFILE} · "
      else
        HEAD=""
      fi

      if [ "${MODE:-api}" = "plan" ]; then
        # SPEC §5bis: premium tokens avoided is the hero, never a $ figure.
        PT="$(humanize "${PREM_TODAY:-0}")"; PA="$(humanize "${PREM_TOTAL:-0}")"
        BAR="$(covbar "${MEASURED:-0}" "${PENDING:-0}" "${UNMEASURED:-0}")"
        MEASPART="${MEASURED:-0} meas"
        # pending count shown here too (parity with api mode): the spinner's
        # motion must never appear without the number that explains it.
        [ "${PENDING:-0}" != "0" ] && MEASPART="${MEASPART} · ${PENDING} pending"
        [ -n "$SPIN" ] && MEASPART="${MEASPART} ${SPIN}"
        [ -n "$BAR" ] && MEASPART="${MEASPART} ${BAR}"
        BODY="${HEAD}${PT} prem tok avoided today · ${PA} total (${MEASPART})"
      else
        TODAYSTR="$(signed_dollar "${NET_TODAY:-0}")"
        TOTALSTR="$(signed_dollar "${NET_TOTAL:-0}")"
        ESCPART=""
        if awk -v n="${NET_TODAY:-0}" 'BEGIN{exit !(n<0)}' 2>/dev/null && [ "${ESC_TODAY:-0}" != "0" ]; then
          ESCWORD="escalations"; [ "${ESC_TODAY:-0}" = "1" ] && ESCWORD="escalation"
          ESCPART=" (${ESC_TODAY} ${ESCWORD})"
        fi
        COVPART=" (${MEASURED:-0} meas"
        [ "${UNMEASURED:-0}" != "0" ] && COVPART="${COVPART} · ${UNMEASURED} unmeas"
        [ "${PENDING:-0}" != "0" ] && COVPART="${COVPART} · ${PENDING} pending"
        [ -n "$SPIN" ] && COVPART="${COVPART} ${SPIN}"
        BAR="$(covbar "${MEASURED:-0}" "${PENDING:-0}" "${UNMEASURED:-0}")"
        [ -n "$BAR" ] && COVPART="${COVPART} ${BAR}"
        COVPART="${COVPART})"
        BODY="${HEAD}${TODAYSTR} today${ESCPART} · ${TOTALSTR} net${COVPART}"
      fi

      # stale marker: NEWEST = max(mtime butin.jsonl, mtime receipts.jsonl),
      # via a stat chain (macOS/BSD vs GNU) — never opens either file's
      # content. generated_epoch comes straight from the cache: no date
      # parsing anywhere in the renderer.
      STALE_TEXT=""
      GE="${GEN_EPOCH:-}"
      case "$GE" in (*[!0-9]*|"") GE="" ;; esac
      if [ -n "$GE" ]; then
        BJ="$AMIRAL_HOME/butin.jsonl"; RJ="$AMIRAL_HOME/receipts.jsonl"
        M1=0; M2=0
        [ -f "$BJ" ] && M1="$(stat -c %Y "$BJ" 2>/dev/null || stat -f %m "$BJ" 2>/dev/null)"
        [ -f "$RJ" ] && M2="$(stat -c %Y "$RJ" 2>/dev/null || stat -f %m "$RJ" 2>/dev/null)"
        case "$M1" in (*[!0-9]*|"") M1=0 ;; esac
        case "$M2" in (*[!0-9]*|"") M2=0 ;; esac
        NEWEST=$M1; [ "$M2" -gt "$NEWEST" ] && NEWEST=$M2
        if [ "$NEWEST" -gt 0 ] && [ $(( NEWEST - GE )) -gt 600 ]; then
          STALE_TEXT=" · stale"
        fi
      fi

      PLAIN="${BODY}${STALE_TEXT}"
      STALE_COLORED=""
      [ -n "$STALE_TEXT" ] && STALE_COLORED=" ${DIMC}· stale${RST}"
      if [ -n "$PROFILE" ]; then
        # Profile token is BOLD CYAN on its own (v0.13.2: was dim) — bold
        # weight for visual presence, a hue that carries no good/bad
        # meaning so it never competes with the sign color (green/amber)
        # the rest of the line takes from today's net. The anchor itself
        # keeps that sign color here, exactly as before.
        BODY_TAIL="${BODY#"${HEAD}"}"
        SEG="${COL}⚓ ${RST}${CYANB}${PROFILE}${RST}${COL} · ${BODY_TAIL}${RST}${STALE_COLORED}"
      else
        SEG="${COL}${BODY}${RST}${STALE_COLORED}"
      fi
    fi
  fi
fi

# Marker-alone fallback: a valid profile with NO money segment (no cache
# file, corrupt cache, or a muted positive day — all three leave SEG empty
# above) still renders the anchor + profile alone, bold cyan (v0.13.2: was
# dim). The marker is session identity, not good news: mute suppresses
# money, never identity.
# Self-contained NO_COLOR handling — the block above may never have run
# (cache missing/corrupt), so CYANB/RST are not guaranteed to be set here.
if [ -z "$SEG" ] && [ -n "$PROFILE" ]; then
  PLAIN="⚓ ${PROFILE}"
  if [ -n "${NO_COLOR:-}" ]; then
    SEG="$PLAIN"
  else
    # bold cyan, matching the full-segment profile token; the anchor may
    # share the cyan here since there is no sign color (no money segment)
    # for it to carry instead.
    SEG="$(printf '\033[1;36m⚓ %s\033[0m' "$PROFILE")"
  fi
fi

# 4. Compose (§1.6): a chained line must survive our degraded states, and we
# must survive an absent/foreign previous line.
if [ -z "$PREV" ]; then
  [ -n "$SEG" ] && printf '%s\n' "$SEG"
elif [ -z "$SEG" ]; then
  printf '%s\n' "$PREV"
else
  FIRST="$(printf '%s\n' "$PREV" | head -1)"
  COLS="${COLUMNS:-120}"
  # `|0`: bash can materialize an exported-but-empty COLUMNS as literal "0"
  # in tty-less contexts; 0 would force the 2-line branch on every render.
  case "$COLS" in (*[!0-9]*|""|0) COLS=120 ;; esac
  # NOTE: LC_ALL=C makes ${#FIRST}/${#PLAIN} count BYTES, and the anchor
  # plus the coverage bar's cells are multibyte UTF-8 glyphs — so this
  # check overestimates visible width and can wrap to two lines slightly
  # earlier than strictly necessary. Conservative-safe direction (it never
  # UNDER-wraps into an overflowing single line); accepted, not fixed.
  if [ $(( ${#FIRST} + ${#PLAIN} + 3 )) -le "$COLS" ] 2>/dev/null; then
    printf '%s · %s\n' "$FIRST" "$SEG"
    printf '%s\n' "$PREV" | tail -n +2
  else
    printf '%s\n' "$PREV"
    printf '%s\n' "$SEG"
  fi
fi

exit 0
