#!/usr/bin/env bash
# amiral journal de bord — provenance for AI-assisted commits. Opt-in,
# per-repo, zero server: trailers live in git, the proof travels with
# the code. "Ship AI-written code you can defend."
# Commands: enable [--with-cost] [--yes] | disable | status | attest | flag
export LC_ALL=C
set -uo pipefail
AMIRAL_HOME="${AMIRAL_HOME:-$HOME/.amiral}"
LOG="$AMIRAL_HOME/butin.jsonl"
CMD="${1:-status}"
# repo checkout, for the AMIRAL_AGENTS manifest fallback below (dev/test
# runs before install.sh has copied anything to $CLAUDE_CONFIG_DIR).
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

repo_root() { git rev-parse --show-toplevel 2>/dev/null; }
# corsaire-3: resolve the REAL hooks dir via `git rev-parse --git-path hooks`
# instead of hardcoding "$ROOT/.git/hooks". In a linked worktree, $ROOT/.git
# is a FILE (a gitdir pointer), not a directory — hardcoding meant mkdir/cat/
# chmod all failed to stderr while `enable` still printed its success banner
# (a false claim of protection). --git-path resolves the actual (shared)
# hooks dir git will use for hooks fired from inside a worktree, and also
# respects a user's core.hooksPath override for free. Verified in both a
# normal repo and a worktree (tests/test-journal.sh J-12) before shipping
# this over the simpler "fail honestly" alternative.
hook_path() {
  local root gitpath
  root=$(repo_root) || return 1
  [ -z "$root" ] && return 1
  gitpath=$(cd "$root" 2>/dev/null && git rev-parse --git-path hooks 2>/dev/null)
  [ -z "$gitpath" ] && return 1
  case "$gitpath" in
    (/*) echo "$gitpath/prepare-commit-msg" ;;
    (*) echo "$root/$gitpath/prepare-commit-msg" ;;
  esac
}

attest_hash() {
  # Amiral-Diff-Digest: sha256(verify.sh bytes + staged diff). Deterministic,
  # recomputable by anyone. Honest framing (H3): this proves the bytes were
  # PRESENT at commit time — it does NOT prove verify.sh ran. Also honest
  # (corsaire, doc-only): `cat ./verify.sh 2>/dev/null` folds in zero bytes
  # for BOTH an absent verify.sh and one that exists but is unreadable
  # (permissions) — self-consistent, but the digest alone cannot tell you
  # which of the two happened.
  { cat ./verify.sh 2>/dev/null; git diff --cached 2>/dev/null; } \
    | shasum -a 256 2>/dev/null | awk '{print substr($1,1,16)}'
}

have_tty() { { : </dev/tty; } 2>/dev/null; }

# C6: whether any remote is worth asking consent for. A DENYLIST of forge
# hostnames (github/gitlab/…) can never enumerate self-hosted or third-party
# public hosts (Bitbucket, Codeberg, a company GitLab, plain ssh), so a
# match-only gate leaks $ figures on every host it forgot. Fail closed the
# other way: treat ANY remote pointing at a network host as consent-worthy,
# and SKIP only obviously-local ones (filesystem paths, loopback). Over-asking
# on a genuinely-private host is harmless (--yes clears it); missing a public
# one is the exact leak this gate exists to stop.
remote_needs_consent() {
  # Loop in the CURRENT shell via process substitution (not `| while`): a
  # `| grep -q` that matched early would send SIGPIPE up to git/awk, and under
  # `set -o pipefail` that 141 surfaces as "false" even when a public remote
  # was found. Process substitution avoids the pipe entirely; _hit persists.
  local _u _hit=""
  while IFS= read -r _u; do
    case "$_u" in
      ''|/*|./*|../*|file://*|~*) : ;;                          # local filesystem path
      *localhost*|*127.0.0.1*|*'[::1]'*) : ;;                   # loopback
      ssh://*|git://*|http://*|https://*|ftp://*|ftps://*|*@*:*) _hit=yes ;;  # network host
    esac
  done < <(git remote -v 2>/dev/null | awk 'NF>=2{print $2}')
  [ -n "$_hit" ]
}

case "$CMD" in
  enable)
    ROOT=$(repo_root) || { echo "not a git repo"; exit 1; }
    WITH_COST=0; ASSUME_YES=0
    shift || true
    for ARG in "$@"; do
      case "$ARG" in
        --with-cost) WITH_COST=1 ;;
        --yes|--assume-yes) ASSUME_YES=1 ;;
      esac
    done
    # C6: this is a security confirmation, not a formality. Amiral-Net-Saved
    # publishes your dollar savings figures into every commit message from
    # here on. On a public remote, that is visible to everyone. Without a
    # controlling terminal there is no way to get real, informed consent, so
    # this gate fails CLOSED instead of silently proceeding: no terminal and
    # no --yes means the hook is NOT installed.
    if [ "$WITH_COST" = "1" ] && remote_needs_consent; then
      if [ "$ASSUME_YES" = "1" ]; then
        echo "Remote detected. Continuing because --yes was passed: consent was given non-interactively, by explicit flag."
      elif have_tty; then
        echo "Warning: a remote was detected (it may be publicly visible). The Amiral-Net-Saved trailer will publish your dollar savings figures into every commit message pushed to it. Press Ctrl-C now to abort, or press Enter to continue."
        # read -t: a tty can be open (docker -t, an output-only pty) with no
        # human to type — an unbounded read would hang, not fail closed. Time
        # out and abort so "no confirmation" always means "not installed".
        # AMIRAL_CONSENT_TIMEOUT only shortens this wait (dev/test convenience,
        # e.g. tests run against a real controlling tty with no human present)
        # — it can never SKIP or auto-confirm the prompt. A shorter timeout
        # only makes the gate fail closed FASTER (timed-out read -> abort ->
        # exit 1 -> hook NOT installed). The only non-interactive consent path
        # is, and remains, the explicit --yes/--assume-yes flag above. Do NOT
        # repurpose this variable into a skip/auto-yes switch.
        _CT="${AMIRAL_CONSENT_TIMEOUT:-60}"
        case "$_CT" in
          ''|*[!0-9]*) _CT=60 ;;
        esac
        [ "$_CT" -ge 1 ] 2>/dev/null || _CT=60
        read -t "$_CT" -r _ </dev/tty || { echo "Aborted: no confirmation was received."; exit 1; }
      else
        echo "Refusing to enable --with-cost: a remote was detected and there is no terminal available to ask for your confirmation." >&2
        echo "The Amiral-Net-Saved trailer would publish your dollar savings figures into every commit message pushed to this (possibly public) repository without your explicit consent." >&2
        echo "Re-run this command in an interactive terminal, or pass --yes if you really mean it." >&2
        exit 1
      fi
    fi
    HOOK_FILE=$(hook_path)
    if [ -z "$HOOK_FILE" ]; then
      echo "journal NOT enabled — could not resolve the hooks directory for $ROOT."
      exit 1
    fi
    mkdir -p "$(dirname "$HOOK_FILE")" 2>/dev/null
    cat > "$HOOK_FILE" << HOOK
#!/usr/bin/env bash
# installed by amiral-journal (remove: amiral-journal disable)
export LC_ALL=C
MSG="\$1"
SRC="\${2:-}"
SHA="\${3:-}"
# idempotence: any prior trailer means this message already went through the
# hook (amend re-runs it on the same message file). ROUTES/DIGEST/Net-Saved
# can each legitimately be empty on their own — checking all three keeps the
# guard correct even when the first pass emitted only one of them; if a
# commit legitimately emitted NONE (nothing to report), re-running finds
# nothing to report again (or genuinely new info) — harmless either way.
grep -qE "Amiral-Route:|Amiral-Diff-Digest:|Amiral-Net-Saved:" "\$MSG" && exit 0
AMIRAL_HOME="\${AMIRAL_HOME:-\$HOME/.amiral}"
ROOT=\$(git rev-parse --show-toplevel 2>/dev/null)
# H4: routes scoped to THIS repo (recorded cwd == root, or under it); events
# with NO cwd (pre-v0.12 events, bash-collector v1) are excluded — never
# guessed. Residual, stated honestly: the window is still "last 50 lines of
# the GLOBAL log, filtered here" — this-repo routes older than that window
# won't appear. Scoping is by recorded cwd (the task's working directory at
# measurement time), not a git-verified fact. Also doc-only (corsaire): the
# comparison below is a raw string match — on a case-insensitive filesystem
# a casing mismatch between recorded cwd and \$ROOT drops a legit route.
# Under-report only, never over-report; accepted.
ROUTES=""
if [ -n "\$ROOT" ]; then
  # corsaire-4: cap input BEFORE the loop — a pathological (e.g. 50MB,
  # unterminated) line must degrade to fewer/absent routes, never stall
  # every commit on the machine. Byte-cap first (a capped mid-line fragment
  # just fails extraction below, harmlessly), then take the usual line
  # window.
  ROUTES=\$(tail -c 200000 "\$AMIRAL_HOME/butin.jsonl" 2>/dev/null | tail -50 | grep -v '"unmeasurable"' | while IFS= read -r EVLINE; do
    [ "\${#EVLINE}" -gt 8000 ] && continue
    CWD=\$(printf '%s\n' "\$EVLINE" | grep -oE '"cwd"[ ]*:[ ]*"[^"]*"' | sed 's/.*"\([^"]*\)"\$/\1/')
    [ -z "\$CWD" ] && continue
    case "\$CWD" in
      ("\$ROOT"|"\$ROOT"/*) ;;
      (*) continue ;;
    esac
    # corsaire-2: agent/chosen_model come from butin.jsonl, a plain
    # user-writable file with no auth — sanitize to the safe set so a
    # hostile value (e.g. one containing a newline-ish payload forging a
    # fake trailer) can only ever contribute inert token characters to the
    # commit message, never structure (newlines, colons, spaces beyond the
    # "=" pair separator we add ourselves). A stripped-empty value drops
    # that pair.
    A=\$(printf '%s\n' "\$EVLINE" | grep -oE '"agent"[ ]*:[ ]*"[^"]*"' | sed 's/.*"\([^"]*\)"\$/\1/' | sed 's/[^A-Za-z0-9._-]//g')
    M=\$(printf '%s\n' "\$EVLINE" | grep -oE '"chosen_model"[ ]*:[ ]*"[^"]*"' | sed 's/.*"\([^"]*\)"\$/\1/' | sed 's/[^A-Za-z0-9._-]//g')
    [ -n "\$A" ] && [ -n "\$M" ] && echo "\$A=\$M"
  done | sort -u | paste -sd' ' -)
fi
# H3: Amiral-Diff-Digest = sha256(verify.sh bytes + the commit's diff). Proves
# the bytes were PRESENT at commit time, not that verify.sh RAN. On amend
# (\$2=commit) the staged diff alone can be empty, so we also fold in the
# COMMITTED diff (git show \$3): message-only amend still carries real
# content instead of degenerating to a hash of nothing.
DIGEST=""
if [ "\$SRC" = "commit" ] && [ -n "\$SHA" ]; then
  DIFFLEN=\$({ git show --format= "\$SHA" 2>/dev/null; git diff --cached 2>/dev/null; } | wc -c | tr -d ' ')
else
  DIFFLEN=\$(git diff --cached 2>/dev/null | wc -c | tr -d ' ')
fi
# doc-only (corsaire): absent verify.sh and unreadable verify.sh both fold in
# zero bytes here (2>/dev/null) — self-consistent, but the digest cannot tell
# the two apart.
HAVE_VERIFY=0; [ -f ./verify.sh ] && HAVE_VERIFY=1
# never emit a digest of provably-empty input (hash-of-nothing is not proof)
if [ "\$DIFFLEN" != "0" ] || [ "\$HAVE_VERIFY" = "1" ]; then
  if [ "\$SRC" = "commit" ] && [ -n "\$SHA" ]; then
    DIGEST=\$({ cat ./verify.sh 2>/dev/null; git show --format= "\$SHA" 2>/dev/null; git diff --cached 2>/dev/null; } | shasum -a 256 2>/dev/null | awk '{print substr(\$1,1,16)}')
  else
    DIGEST=\$({ cat ./verify.sh 2>/dev/null; git diff --cached 2>/dev/null; } | shasum -a 256 2>/dev/null | awk '{print substr(\$1,1,16)}')
  fi
fi
{
  echo ""
  [ -n "\$ROUTES" ] && echo "Amiral-Route: \$ROUTES"
  [ -n "\$DIGEST" ] && echo "Amiral-Diff-Digest: sha256:\$DIGEST"
HOOK
    if [ "$WITH_COST" = "1" ]; then
      cat >> "$HOOK_FILE" << 'HOOK'
  # amiral-attributed net only: build the agent set from the SAME shared
  # helper every other call site uses, so this commit trailer never advertises
  # the mixed total (the exact over-claim the report fix exists to kill) and
  # the sanitization rule can't drift. Helper/manifest absent -> empty
  # AMIRAL_AGENTS -> core.awk's legacy all-amiral fallback, same as everywhere.
  AMIRAL_AGENTS=""
  AGENTS_SH="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/butin/agents.sh"
  [ -f "$AGENTS_SH" ] && . "$AGENTS_SH" && command -v amiral_agents_csv >/dev/null 2>&1 \
    && AMIRAL_AGENTS="$(amiral_agents_csv)"
  NET=$(awk -F'\t' '/^NET/{print $2}' <(awk -v AMIRAL_AGENTS="$AMIRAL_AGENTS" -f "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/butin/core.awk" "$AMIRAL_HOME/butin.jsonl" 2>/dev/null) 2>/dev/null)
  [ -n "$NET" ] && echo "Amiral-Net-Saved: \$$NET (net, escalations deducted; amiral-routed only)"
HOOK
    fi
    { echo '} >> "$MSG"'; echo 'exit 0'; } >> "$HOOK_FILE"
    # trailing exit 0 is load-bearing: the group's exit status is its last
    # command's, and Route/Digest/Net-Saved are now each conditional — if the
    # last one evaluates false the hook would exit nonzero and ABORT the
    # commit (this bookkeeping hook must never block a commit).
    chmod +x "$HOOK_FILE" 2>/dev/null
    # corsaire-3: verify the hook actually landed before claiming success —
    # in a worktree $ROOT/.git used to be hardcoded to a path that's a FILE
    # there, so mkdir/cat/chmod silently failed to stderr while this banner
    # still printed (a false claim of protection). hook_path() above now
    # resolves the real (shared) hooks dir via `git rev-parse --git-path
    # hooks`, which works from inside a worktree too; this check is the
    # last line of defense if the write still fails for some other reason
    # (permissions, read-only fs, etc).
    if [ -f "$HOOK_FILE" ] && [ -x "$HOOK_FILE" ]; then
      echo "⚓ journal enabled for this repo (trailers: Route + Diff-Digest$( [ "$WITH_COST" = "1" ] && echo " + Net-Saved" ))."
      echo "  disable anytime: amiral-journal disable"
    else
      echo "journal NOT enabled — hook failed to install at $HOOK_FILE"
      exit 1
    fi ;;
  disable)
    rm -f "$(hook_path)" && echo "journal disabled (hook removed)." ;;
  status)
    if [ -x "$(hook_path)" 2>/dev/null ]; then echo "journal: ENABLED in $(repo_root)"; else echo "journal: disabled here (enable: amiral-journal enable)"; fi ;;
  note)
    # squash-merge survivors: same provenance as a git note on HEAD.
    # Digest covers the COMMITTED diff (git show HEAD), recomputable.
    ROOT=$(repo_root) || { echo "not a git repo"; exit 1; }
    # H4: same repo-scoping as the hook — cwd == ROOT or under it; cwd-less
    # (legacy) events excluded, never guessed. See amiral-journal enable for
    # the residual-window note (last 50 lines of the global log, filtered).
    # Also doc-only (corsaire): the comparison is a raw string match — on a
    # case-insensitive filesystem a casing mismatch drops a legit route
    # (under-report only, never over-report; accepted).
    # corsaire-4: same byte-cap + per-line-length guard as the hook — a
    # pathological line must not stall this command either.
    ROUTES=$(tail -c 200000 "$LOG" 2>/dev/null | tail -50 | grep -v '"unmeasurable"' | while IFS= read -r EVLINE; do
      [ "${#EVLINE}" -gt 8000 ] && continue
      CWD=$(printf '%s\n' "$EVLINE" | grep -oE '"cwd"[ ]*:[ ]*"[^"]*"' | sed 's/.*"\([^"]*\)"$/\1/')
      [ -z "$CWD" ] && continue
      case "$CWD" in
        ("$ROOT"|"$ROOT"/*) ;;
        (*) continue ;;
      esac
      # corsaire-2: same sanitization as the hook — agent/chosen_model come
      # from an unauthenticated local file and may only contribute inert
      # token characters, never structure.
      A=$(printf '%s\n' "$EVLINE" | grep -oE '"agent"[ ]*:[ ]*"[^"]*"' | sed 's/.*"\([^"]*\)"$/\1/' | sed 's/[^A-Za-z0-9._-]//g')
      M=$(printf '%s\n' "$EVLINE" | grep -oE '"chosen_model"[ ]*:[ ]*"[^"]*"' | sed 's/.*"\([^"]*\)"$/\1/' | sed 's/[^A-Za-z0-9._-]//g')
      [ -n "$A" ] && [ -n "$M" ] && echo "$A=$M"
    done | sort -u | paste -sd' ' -)
    AH=$({ cat ./verify.sh 2>/dev/null; git show --format= HEAD 2>/dev/null; } \
      | shasum -a 256 2>/dev/null | awk '{print substr($1,1,16)}')
    N="Amiral-Route: ${ROUTES:-unknown}
Amiral-Diff-Digest: sha256:$AH (verify.sh + committed diff — proves what was present, not what was run)
Amiral-Noted: $(date -u +%FT%TZ)"
    git notes --ref=amiral add -f -m "$N" HEAD && echo "⚓ note attached to HEAD (ref: amiral)."
    echo "  notes don't push by default: git push origin refs/notes/amiral" ;;
  attest)
    echo "Amiral-Diff-Digest: sha256:$(attest_hash)  (recompute: cat verify.sh + git diff --cached | sha256 — proves what was present, not what was run)" ;;
  flag)
    # v0.15: amiral-attributed agent set — the badge must never credit
    # amiral for subagent activity it didn't route (same manifest as
    # bin/amiral-butin and cache.sh). Both the NET *and* the task count on
    # the badge are amiral-routed only: advertising a mixed task count next
    # to an amiral-only net is the same over-claim, one column over.
    AGENTS_SH="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/butin/agents.sh"
    [ -f "$AGENTS_SH" ] || AGENTS_SH="$HERE/lib/butin/agents.sh"
    AMIRAL_AGENTS=""
    [ -f "$AGENTS_SH" ] && . "$AGENTS_SH"
    command -v amiral_agents_csv >/dev/null 2>&1 && AMIRAL_AGENTS="$(amiral_agents_csv "$HERE/lib/butin/amiral-agents.txt")"
    # installed core.awk first, then the repo checkout — same fallback idiom as
    # bin/amiral-butin and lib/butin/cache.sh. Without it, running `flag` from a
    # fresh clone (before install.sh) read no calculator and misreported 0 tasks;
    # and it kept the badge pinned to a stale installed core.awk. One calculator.
    CORE_J="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/butin/core.awk"
    [ -f "$CORE_J" ] || CORE_J="$HERE/lib/butin/core.awk"
    REPORT=$(awk -v AMIRAL_AGENTS="$AMIRAL_AGENTS" -f "$CORE_J" "$LOG" 2>/dev/null)
    NET=$(echo "$REPORT" | awk -F'\t' '/^NET/{print $2}')
    # AMIR_TASKS = amiral-routed measured tasks (sum of the AGENTS_START block's
    # Tasks column — brain and other-bucket agents never appear there).
    AMIR_TASKS=$(echo "$REPORT" | awk -F'\t' '/^AGENTS_START/{p=1;next}/^AGENTS_END/{p=0}p{s+=$2}END{print s+0}')
    OTHER_TASKS=$(echo "$REPORT" | awk -F'\t' '/^OTHER_TASKS/{print $2}'); OTHER_TASKS=${OTHER_TASKS:-0}
    MEAS=$(grep -c '"real_cost_usd"' "$LOG" 2>/dev/null || echo 0)
    # pavillon — refuses to lie small (rule C3): >=20 AMIRAL-ROUTED tasks. The
    # badge advertises amiral's routing, so the gate is on amiral data, not on
    # foreign subagent volume the tool happened to also measure.
    if [ "${AMIR_TASKS:-0}" -lt 20 ]; then
      echo "pavillon: not enough amiral-routed data to share honestly yet ($AMIR_TASKS/20 amiral-routed tasks)."; exit 1
    fi
    echo "[![sailed with amiral](https://img.shields.io/badge/⚓_sailed_with_amiral-${AMIR_TASKS}_amiral--routed_tasks_·_net_%2B\$${NET}-2b4c7e)](https://github.com/Rompomepome/amiral/blob/main/BENCHMARKS.md)"
    echo "coverage: $AMIR_TASKS amiral-routed · $OTHER_TASKS other subagent task(s) measured separately · net of escalations & brain premium · methodology in BENCHMARKS.md" ;;
  *) echo "usage: amiral-journal enable [--with-cost] [--yes] | disable | status | attest | note | flag"; exit 1 ;;
esac
