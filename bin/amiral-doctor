#!/usr/bin/env bash
# amiral doctor — checks that the fleet is actually sailing.
# Diagnoses the #1 silent failure: workers falling back to the expensive
# brain because the hands model doesn't resolve.
set -uo pipefail

CLAUDE_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
PASS=0; WARN=0; FAIL=0
ok()   { echo "  [ok]   $1"; PASS=$((PASS+1)); }
warn() { echo "  [warn] $1"; WARN=$((WARN+1)); }
fail() { echo "  [FAIL] $1"; FAIL=$((FAIL+1)); }

echo "amiral doctor — the admiral doesn't row"
echo

echo "-- Claude Code --"
if command -v claude >/dev/null 2>&1; then
  V="$(claude --version 2>/dev/null | head -1 || true)"
  ok "claude found: ${V:-unknown version}"
  case "$V" in
    *" 2.0."*|*" 2.1.0"*|*" 2.1.1"[0-8]*)
      warn "version may predate v2.1.197 (Sonnet 5). Run: claude update" ;;
  esac
else
  fail "'claude' not in PATH — install Claude Code first"
fi

echo "-- Install --"
[ -f "$CLAUDE_DIR/amiral-policy.md" ] && ok "policy installed" || fail "policy missing — run ./install.sh (or /plugin install)"
if [ -f "$CLAUDE_DIR/CLAUDE.md" ] && grep -q 'amiral-policy.md' "$CLAUDE_DIR/CLAUDE.md"; then
  ok "policy imported in CLAUDE.md"
else
  warn "policy not imported in $CLAUDE_DIR/CLAUDE.md (plugin install covers agents/skills but not the global policy)"
fi
M=0; for a in implementer grunt reviewer corsaire; do [ -f "$CLAUDE_DIR/agents/$a.md" ] && M=$((M+1)); done
if [ "$M" = "4" ]; then ok "4 fleet agents installed"; else
  # plugin path: agents live in the plugin cache, not ~/.claude/agents
  warn "$M/4 agents in $CLAUDE_DIR/agents (fine if installed via /plugin — check /agents inside a session)"
fi
[ -f "$CLAUDE_DIR/amiral-profiles.sh" ] && ok "shell profiles present" || warn "shell profiles not in $CLAUDE_DIR (curl them from the repo)"

echo "-- Shell --"
for rc in "$HOME/.zshrc" "$HOME/.bashrc"; do
  if [ -f "$rc" ] && grep -q 'amiral-profiles.sh' "$rc"; then ok "sourced in ${rc##*/}"; SOURCED=1; fi
done
[ "${SOURCED:-0}" = "1" ] || warn "profiles not sourced in ~/.zshrc or ~/.bashrc"

echo "-- Fleet config --"
echo "  brain: ${AMIRAL_BRAIN:-fable (default)}"
echo "  hands: ${AMIRAL_HANDS:-sonnet (default)}"
case "${AMIRAL_BRAIN:-fable}" in
  fable*) warn "brain=fable: from July 8, 2026, Fable is usage-credits only on subscriptions (no auto-fallback — access stops if credits are off). Enable credits, or run AMIRAL_BRAIN=opus for a pure-subscription fleet." ;;
esac
case "${AMIRAL_HANDS:-sonnet}" in
  claude-*) ok "hands pinned to a full model ID (most robust)" ;;
  *) warn "hands uses an alias ('${AMIRAL_HANDS:-sonnet}'). If workers show the brain model in /agents, pin it: export AMIRAL_HANDS=claude-sonnet-5" ;;
esac

echo "-- Current project --"
if [ -x ./verify.sh ]; then
  ok "verify.sh found here — the fleet has a machine-checkable done gate"
  TRUST_FILE="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/amiral-trusted-repos"
  RR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
  FP="$RR::$(shasum ./verify.sh 2>/dev/null | awk '{print $1}')"
  if [ -f "$TRUST_FILE" ] && grep -qxF "$FP" "$TRUST_FILE" 2>/dev/null; then
    ok "this verify.sh is trusted for the SubagentStop hook"
  else
    echo "  [i]    verify.sh not trusted for the hook (run 'amiral-trust' if you use the hook here)"
  fi
elif [ -d .git ]; then
  warn "no ./verify.sh in this project — plans can't self-verify. Grab templates/verify-nextjs.sh from the amiral repo."
else
  echo "  [i]    not inside a project (run from a repo to check its done gate)"
fi

echo "-- Live routing check (manual, one time) --"
echo "  1. run:  amiral        (in any project)"
echo "  2. ask:  'implement a tiny change using the implementer agent'"
echo "  3. check /agents or the transcript: worker model must be the"
echo "     HANDS model, not the brain. Silent fallback = quota bleed."
echo "  note: Fable's safety classifiers can reroute a session to Opus"
echo "  from the first message (workspace context). Debug: claude --safe-mode"

echo
echo "Summary: $PASS ok, $WARN warn, $FAIL fail"
[ "$FAIL" = "0" ] || exit 1
